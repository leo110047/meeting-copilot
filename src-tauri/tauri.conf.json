{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meeting Copilot",
  "version": "0.1.0",
  "identifier": "dev.leo.meeting-copilot",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Meeting Copilot",
        "width": 1080,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "visible": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/meeting-copilot-native-speech", "binaries/meeting-copilot-whisper"],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
